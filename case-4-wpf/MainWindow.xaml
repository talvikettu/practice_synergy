<Window x:Class="Case4Calculator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Интерактивный калькулятор"
        Height="420"
        Width="680"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="#10212B">
    <Window.Resources>
        <Style x:Key="ActionButtonStyle" TargetType="Button">
            <Setter Property="Padding" Value="12" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="Wheat" />
            <Setter Property="Foreground" Value="Black" />
            <Setter Property="BorderThickness" Value="0" />
        </Style>
    </Window.Resources>
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Margin="0 0 0 20">
            <TextBlock Text="Кейс-задача № 4"
                       Foreground="#F3E9D2"
                       FontSize="16"
                       FontWeight="SemiBold" />
            <TextBlock Text="Интерактивный калькулятор"
                       Foreground="White"
                       FontSize="28"
                       FontWeight="Bold" />
            <TextBlock Text="Введите два числа и выберите математическую операцию."
                       Foreground="#D8D2C4"
                       Margin="0 8 0 0" />
        </StackPanel>

        <Grid Grid.Row="1" Margin="0 0 0 18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="16" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBox x:Name="FirstNumberTextBox"
                     Grid.Column="0"
                     Padding="14"
                     FontSize="16"
                     BorderThickness="0"
                     Background="#F3F0E8"
                     ToolTip="Первое число" />
            <TextBox x:Name="SecondNumberTextBox"
                     Grid.Column="2"
                     Padding="14"
                     FontSize="16"
                     BorderThickness="0"
                     Background="#F3F0E8"
                     ToolTip="Второе число" />
        </Grid>

        <UniformGrid Grid.Row="2" Columns="4" Margin="0 0 0 18">
            <Button Content="Сумма" Click="Sum_Click" Margin="0 0 12 0" Style="{StaticResource ActionButtonStyle}" />
            <Button Content="Разность" Click="Subtract_Click" Margin="0 0 12 0" Style="{StaticResource ActionButtonStyle}" />
            <Button Content="Произведение" Click="Multiply_Click" Margin="0 0 12 0" Style="{StaticResource ActionButtonStyle}" />
            <Button Content="Деление" Click="Divide_Click" Style="{StaticResource ActionButtonStyle}" />
        </UniformGrid>

        <Border Grid.Row="3"
                CornerRadius="22"
                Padding="22"
                Background="#1B3846">
            <StackPanel>
                <TextBlock Text="Результат"
                           Foreground="#F7E7C6"
                           FontSize="16"
                           FontWeight="SemiBold" />
                <TextBlock x:Name="ResultTextBlock"
                           Margin="0 10 0 0"
                           Text="Здесь появится результат вычисления."
                           TextWrapping="Wrap"
                           Foreground="White"
                           FontSize="22"
                           FontWeight="Bold" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
